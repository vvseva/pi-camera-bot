[Unit]
Description=Master Camera Telegram Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=vvseva
WorkingDirectory=/home/vvseva/pi_bots
ExecStart=/home/vvseva/pi_bots/bot_env/bin/python /home/vvseva/pi_bots/master_bot.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
